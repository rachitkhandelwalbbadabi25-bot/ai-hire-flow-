rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Globals & Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email.lower() == "rrachitkhandelwal8@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }
    
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 1. User Profile Rules
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      allow create: if isOwner(userId) && (
        incoming().plan == 'admin' ? request.auth.token.email.lower() == "rrachitkhandelwal8@gmail.com" : true
      );

      allow update: if isOwner(userId) && (
        (incoming().plan != existing().plan ? (
           incoming().plan == 'admin' ? request.auth.token.email.lower() == "rrachitkhandelwal8@gmail.com" : 
           incoming().plan == 'premium' ? isAdmin() : 
           true
        ) : true)
      );

      // Support Sub-collections (Resumes, Jobs, Simulations, Config, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // 5. Admins Collection (Direct Auth)
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; 
    }
  }
}
